# OpenAI API Key (required for runtime)
OPENAI_API_KEY=your-api-key-here

# Model configuration (optional, defaults shown)
OPENAI_MODEL_PRIMARY=gpt-5.1
OPENAI_MODEL_FALLBACK=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# MCP Notes server URL (optional, default shown)
MCP_NOTES_URL=http://localhost:8787/sse

# API server port (optional)
API_PORT=3001

# MCP Notes server port (optional)
MCP_NOTES_PORT=8787

# ============================================
# OAuth2 Proxy Authentication (optional)
# ============================================
# To enable Google authentication:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: http://localhost:4180/oauth2/callback
# 4. Copy Client ID and Client Secret below

# Google OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cookie secret (generate with: openssl rand -base64 32 | tr -- '+/' '-_')
OAUTH2_PROXY_COOKIE_SECRET=your-random-32-byte-secret-here

# Restrict authentication to specific email domain
# OAUTH2_PROXY_EMAIL_DOMAINS=gianlucaformica.net

# Enable authentication in the API (set to true when using oauth2_proxy)
AUTH_ENABLED=false
